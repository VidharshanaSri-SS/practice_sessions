# include <stdio.h>
int main(){
    int a, count=0;
    printf("emter the number :");
    scanf("%d",&a); 
    for(int i=a;i!=0;i/=10){
        for(int j=2;j<a;j++){
            if(i%j==0){
                count++;
            }
        }
    }
    if(count==0){
        printf("prime number");
    }else{
        printf("composite number");
    }
}
